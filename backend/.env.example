APP_NAME=Kios Sidomakmur API
APP_ENV=development
APP_DEBUG=true
APP_AUTO_SEED_DEMO=true
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./kios_sidomakmur.db
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-super-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
GUEST_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
DEFAULT_BRAND_CODE=sidomakmur
DEFAULT_BRAND_NAME=Sidomakmur
DEFAULT_STORE_CODE=SIDO-JATIM-ONLINE
DEFAULT_STORE_NAME=Kios Sidomakmur Jawa Timur
DUITKU_MERCHANT_CODE=DXXXX
DUITKU_API_KEY=change-me
DUITKU_BASE_URL=https://sandbox.duitku.com/webapi/api/merchant
GOOGLE_OIDC_AUDIENCE=
GOOGLE_OIDC_AUDIENCES=
SIGE_SYNC_BASE_URL=https://api.sigemanajer.local
SIGE_SYNC_TOKEN=change-me
SIGE_SYNC_TARGET_CODE=SIDOMAKMUR_KIOS
SIGE_SYNC_TIMEOUT_SECONDS=30
